# ── Database (account-chaomarket-database container) ──
DATABASE_URL=postgresql://admin:hau123@localhost:5434/account_chaomarket

# ── Admin Database (shared brand settings) ──
ADMIN_DATABASE_URL=postgresql://admin:hau123@localhost:5432/admin_chaomarket

# ── NextAuth ──
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-secret-key-must-be-at-least-32-characters-long

# ── Cookie Domain (production only) ──
# COOKIE_DOMAIN=.chaomarket.com

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Brevo Email API ──
BREVO_API_KEY=your-brevo-api-key

# ── Cloudflare R2 Storage (Avatar uploads) ──
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_PUBLIC_URL=https://cdn-account.chaomarket.com

# ── PayOS (Payment gateway) ──
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key

# ── License API ──
LICENSE_API_SECRET=your-license-api-secret

# ── Logging (Logtail / Better Stack) ──
# LOGTAIL_SOURCE_TOKEN=your-logtail-token
# LOG_LEVEL=info

# ── Google Analytics ──
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Web Vitals Reporting ──
# NEXT_PUBLIC_ENABLE_VITALS_REPORTING=true

# ── Sentry (Error monitoring — auto-configured in next.config.ts) ──
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
