# ── Database (account-chaomarket-database container) ──
DATABASE_URL=postgresql://admin:hau123@localhost:5434/account_chaomarket

# ── NextAuth ──
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-secret-key-must-be-at-least-32-characters-long

# ── Cookie Domain (production only) ──
# COOKIE_DOMAIN=.chaomarket.com

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Brevo Email API ──
BREVO_API_KEY=your-brevo-api-key
