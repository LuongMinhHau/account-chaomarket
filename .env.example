# ── Database ──
DATABASE_URL=postgresql://user:password@localhost:5432/chaomarket

# ── NextAuth ──
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=your-secret-key-must-match-chaomarket-web

# ── Cookie Domain (production only) ──
# COOKIE_DOMAIN=.chaomarket.com

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Brevo Email API ──
BREVO_API_KEY=your-brevo-api-key
